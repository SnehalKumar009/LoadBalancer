# NOTE: No longer used for load balancing.
# ATS 10 removed `proxy.config.http.parent_proxy_routing_enable`, so this legacy
# parent.config round-robin never engaged. Load balancing is now done via a shared
# Docker network alias ("backend") that resolves to app1..app4, with ATS HostDB
# strict round-robin spreading requests across those A-records (see remap.config
# and records.yaml). This file is kept only for reference.
# dest_domain=origin.internal parent="app1:8080|app2:8080|app3:8080|app4:8080" round_robin=strict go_direct=false

