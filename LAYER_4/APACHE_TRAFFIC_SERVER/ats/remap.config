# Forward requests to the shared Docker network alias "backend", which resolves
# to all 4 app containers (app1..app4). ATS HostDB round-robins across those
# A-records, giving L7 load balancing without the deprecated parent.config.
#
# One rule per inbound host[:port] clients use to reach ATS:
map http://ats-lb:8080/   http://backend:8080/
map http://localhost:8088/ http://backend:8080/
map http://localhost:8080/ http://backend:8080/
map http://127.0.0.1:8088/ http://backend:8080/

